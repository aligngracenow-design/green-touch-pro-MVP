# Green Touch Pro Backend Environment
PORT=4000
JWT_SECRET=change-this-to-a-long-random-string-in-production
NODE_ENV=development
# Comma-separated allowed origins for CORS (frontend URLs)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
# Optional: path to SQLite DB file (defaults to ./data/greentouch.db)
DB_PATH=./data/greentouch.db

# ─── AI Assistant (LLM) ──────────────────────────────────────────
# The assistant uses an OpenAI-compatible Chat Completions API.
# Works with OpenAI, OpenRouter, Groq, Together, local Ollama, etc.
# Leave LLM_API_KEY empty to use the built-in rule-based responder (demo mode).
#
# --- OpenAI ---
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
#
# --- OpenRouter ---
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-...
# LLM_MODEL=anthropic/claude-3.5-sonnet
#
# --- Groq (fast + free tier) ---
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile
#
# --- Local Ollama (free, no key) ---
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.2:3b
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
