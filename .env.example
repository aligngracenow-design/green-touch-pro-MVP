# Frontend environment
# Leave unset to use the Vite dev proxy (/api -> localhost:4000) in dev,
# or to auto-fall-back to demo/mock mode when no backend is reachable (e.g. Lovable preview).
# Set this to your deployed backend URL in production, e.g.:
# VITE_API_URL=https://your-backend.onrender.com/api
VITE_API_URL=
